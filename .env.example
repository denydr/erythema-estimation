# Copy to .env and fill in your values. Never commit .env.
# Dataset access: https://hyperskinsiteapp--hyperskinwebapp.asia-east1.hosted.app/dataAccess

# From your dataset access email — used by scripts/extract_dataset.py
HYPERSKIN_PASS=your_password_here

# Name you gave your Google Drive remote when running rclone config
RCLONE_REMOTE=gdrive_thesis

# Path to Hyper-Skin(RGB, VIS)/ — printed by extract_dataset.py after extraction
DATA_ROOT="/path/to/Hyper-Skin(RGB, VIS)"