# Copy this file to .env and fill in your local path.
# .env is gitignored and never committed.
#
# DATA_ROOT must point to the Hyper-Skin(RGB, VIS) folder —
# the directory that directly contains train/, test/, and valid/ subfolders.
#
# Dataset access request: https://hyperskinsiteapp--hyperskinwebapp.asia-east1.hosted.app/dataAccess
# After approval you will receive a download link for Hyper-Skin.7z.
# Extract it; inside you will find Hyper-Skin(RGB, VIS)/ — point DATA_ROOT there.

DATA_ROOT=/path/to/Hyper-Skin(RGB, VIS)
